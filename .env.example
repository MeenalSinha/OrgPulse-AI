# --- Backend ---
ENV=development
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000

# Set to "live" once you've wired at least one real MCP server URL below.
MCP_MODE=mock

# --- AI ---
# Optional. When set, /api/chat has Claude compose the final answer from the
# same pre-retrieved, graph-grounded evidence the template uses (strict
# "evidence-only" system prompt - see backend/app/services/rag_service.py).
# If unset, or if the Claude call fails for any reason, the service fails
# open to a deterministic, fully-cited template answer.
ANTHROPIC_API_KEY=

# --- Slack ---
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- Datastores (used once you move off the JSON fixtures) ---
DATABASE_URL=postgresql://orgpulse:orgpulse@localhost:5432/orgpulse
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=orgpulse123
REDIS_URL=redis://localhost:6379/0

# --- MCP server URLs (only needed when MCP_MODE=live) ---
GITHUB_MCP_URL=
JIRA_MCP_URL=
NOTION_MCP_URL=
CONFLUENCE_MCP_URL=
GDRIVE_MCP_URL=
SLACK_MCP_URL=
GCAL_MCP_URL=
LINEAR_MCP_URL=
FIGMA_MCP_URL=
GITLAB_MCP_URL=
AZURE_DEVOPS_MCP_URL=

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
